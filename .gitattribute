# Set default behavior to automatically normalize line endings to LF on commit
* text=auto

# Force specific file types to ALWAYS use LF (Unix/macOS style)
*.sh text eol=lf
*.js text eol=lf
*.json text eol=lf

# Force specific file types to ALWAYS use CRLF (Windows style)
*.bat text eol=crlf
*.ps1 text eol=crlf

# Tell Git which files are binary so it doesn't try to change their line endings
*.png binary
*.jpg binary
*.pdf binary
