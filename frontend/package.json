{
  "name": "dashboard",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest",
    "e2e": "playwright test --config=playwright.fast.config.ts",
    "e2e:fast": "playwright test --config=playwright.fast.config.ts",
    "lint": "tsc --noEmit",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "21.2.4",
    "@angular/common": "21.2.4",
    "@angular/compiler": "21.2.4",
    "@angular/core": "21.2.4",
    "@angular/forms": "21.2.4",
    "@angular/platform-browser": "21.2.4",
    "@angular/platform-browser-dynamic": "21.2.4",
    "@angular/router": "21.2.4",
    "@stomp/stompjs": "^7.3.0",
    "chart.js": "^4.5.1",
    "ng2-charts": "^6.0.1",
    "rxjs": "~7.8.0",
    "sockjs-client": "^1.6.1",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.2.3",
    "@analogjs/vitest-angular": "^2.2.3",
    "@angular/build": "21.2.1",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "21.2.4",
    "@playwright/test": "^1.58.2",
    "@types/sockjs-client": "^1.5.4",
    "jsdom": "^28.1.0",
    "k6": "^0.0.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "undici": "7.24.1"
  }
}
